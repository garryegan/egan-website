CREATE TABLE IF NOT EXISTS "Maps" (
    ID INTEGER PRIMARY KEY,
    TripID INTEGER,
    Name TEXT,
    address TEXT,
    Country TEXT,
    VisitDate TEXT CHECK (
        VisitDate IS NULL
        OR (
            (
                VisitDate GLOB '[1-9] * *[0-9][0-9][0-9][0-9]'
                OR VisitDate GLOB '[12][0-9] * *[0-9][0-9][0-9][0-9]'
                OR VisitDate GLOB '3[01] * *[0-9][0-9][0-9][0-9]'
            )
            AND (
                VisitDate LIKE '% January %'
                OR VisitDate LIKE '% February %'
                OR VisitDate LIKE '% March %'
                OR VisitDate LIKE '% April %'
                OR VisitDate LIKE '% May %'
                OR VisitDate LIKE '% June %'
                OR VisitDate LIKE '% July %'
                OR VisitDate LIKE '% August %'
                OR VisitDate LIKE '% September %'
                OR VisitDate LIKE '% October %'
                OR VisitDate LIKE '% November %'
                OR VisitDate LIKE '% December %'
            )
        )
    ),
    Description TEXT,
    Latitude REAL,
    Longitude REAL,
    photo TEXT,
    hide INTEGER
);
