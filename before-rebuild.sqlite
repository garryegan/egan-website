CREATE TABLE MarketHours (
    market_id INTEGER NOT NULL,
    day_of_week TEXT NOT NULL,
    hours TEXT NOT NULL,
    PRIMARY KEY (market_id, day_of_week),
    FOREIGN KEY (market_id) REFERENCES "Markets"(market_id) ON DELETE CASCADE
);
