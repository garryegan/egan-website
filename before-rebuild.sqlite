CREATE TABLE Trips (
    TripID       INTEGER PRIMARY KEY,
    trip         TEXT NOT NULL,
    icon_colour  TEXT NOT NULL,
    description  TEXT
, Displayed INTEGER NOT NULL DEFAULT 0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(1,'1998: Disneyland','Red','This was our first overseas family holiday to Disneyland Anaheim USA (disregrading our overseas living in Jakarta Indonesia)',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(2,'2003: Canada & USA','Blue',replace('For a black sock dinner party in Windsor Canada and meeting Melinda in Rockchester to travel around Niagara and Lake Erie then onto New York.\nWe said goodbye to Melinda in New York as she continued her separate travels and we headed home via Hawaii for a final pitstop.','\n',char(10)),0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(3,'2005/2006: Central America','Green','Garry, Judy & Kate travelled to Belize Central America via San Francisco to meet Melinda who was studying and living in Belize. From Belize we travelled throughout the country into Guatemala and then back into Belize before leaving for home via Los Angeles and Disneyland.',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(4,'2007: Thailand','Yellow',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(5,'2007/2008: UK & Europe','Orange','This was a very big 3 to 4 month trip with Kate having 6 months off from university following her biomedical masters degree and her starting medicine. We departed in late November and returned at the end of March travelling through the United Kingdom and then western Europe. Judy joined us in Paris on Christmas Eve and Melinda later in Early January in Venice with Judy and Melinda leaving for home at the end of January and Kate and Garry continuing for another month.',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(6,'2009: Japan','Purple','A short 3 week trip to central Japan with Judy, Kate and Garry',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(7,'2009: Egypt & Jordan','Pink','After the Melinda & Joff wedding, Kate & Garry departed on a nominal 3 week tour (Intrepid) of Egypt and Jordan finishing up for 3 nights at the exquisite Marriott Hotel on the Dead Sea (Jordan) before flying home',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(8,'2010/2011: Vietnam & Cambodia','Brown',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(9,'2011: Ireland','Cyan','This was a trip that I had dreamed about fror many years - to take Dad & Mum on a trip to Ireland (their very first overseas trip). Anthony accompanied me as it was a lot to manage them as they were not too agile. Regardless they has a wonderful time and regualrly spoke about it for many years theerafter.',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(10,'2012: New Zealand','Magenta',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(11,'2013: France & UK','Lime',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(12,'2014: Asia, Russia & Scandinavia','Teal',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(13,'2015: Bali (Judy 60th)','Indigo','The whole family travelled to Seminyak, Bali for a week to celebrate Judy''s 60th birthday',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(14,'2016: Italy','Violet',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(15,'2017/2018: Singapore','Olive',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(16,'2019: Western Europe','Maroon',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(17,'2019: Central Otago NZ','Gold','The Egans and Schots did a week long trip to Queenstown, New Zealand and Central Otago for sightseeing and of course wine tasting',0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(18,'2022/2023: Malaysia','Crimson',replace('Another short 3 week trip with Kate, Judy & Garry to visit Kuala Lumpur for both Christams lunch and celebrate NYE from a rooftop bar.\nWe also travelled down to Melaka and its wonderful history and well preserved buildings; on our way back to KL, we visited the very famour Batu Caves.\nWe left KL and travelled by train to Georgetown on Penang Island for a wonderful foodie experience.','\n',char(10)),0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(19,'2023: Europe (Garry''s 70th)','DarkBlue',replace('The whole family travelled to France and Greece to celebrate Garry''s 70th.\nThe highlights were Nantes, France with its huge mechnical elephant and their Natural History Museum which was very comprehensive with the girls having great fun discovering all the various exhibits.\nAthens speaks for itself with it many antiquities but our daytrip to Hydra was sensational with swimming and horse riding.\nWe departed Athens to go to Corfu via Meteora to visit the monastrieds perched orecariousaly on top of very tall rock pinnacles.\nCorfu was magic with a day boating, a wonderful lunch at The White House, swimming at a very popular rock pool.\nOur last leg was a week in Paris which speaks for itself although some of us snuck out to take a fast train to Reims and of course we visited Disneyland where we caught up with Melanie, Clayton and family.','\n',char(10)),0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(20,'2024: Sri Lanka','DarkGreen',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(21,'2025: Singapore (Judy 70th)','DarkOrange',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(22,'2026: The Balkans','DarkRed',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(23,'2026/2027: Bali','DeepPink','For a quick summer trip to Sanur, Bali with Garry, Judy, Kate & Arthur',1);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(60,'Australian local travel','Gold',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(91,'Home','Gray',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(92,'Business','LightGray',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(103,'Future Trip 3','Firebrick',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(104,'Future Trip 4','ForestGreen',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(105,'Future Trip 5','MediumBlue',NULL,0);
INSERT INTO "Trips" ("TripID","trip","icon_colour","description","Displayed") VALUES(106,'Future Trip 6','MediumVioletRed',NULL,0);
