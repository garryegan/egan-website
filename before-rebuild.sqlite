DELETE FROM sqlite_sequence;
INSERT INTO "sqlite_sequence" ("name","seq") VALUES('Markets',7);
CREATE VIEW CaptionCountriesView AS
WITH Cleaned AS (
    SELECT
        Country,
        VisitDate
    FROM Maps
    WHERE Country IS NOT NULL
      AND Country <> ''
),

Parsed AS (
    SELECT
        Country,
        VisitDate,

        -- Day
        CASE
            WHEN VisitDate LIKE '% % %'
                THEN CAST(substr(VisitDate, 1, instr(VisitDate, ' ') - 1) AS INTEGER)
            ELSE 1
        END AS DayNum,

        -- Month
        CASE
            WHEN VisitDate LIKE '% January %' THEN 1
            WHEN VisitDate LIKE '% February %' THEN 2
            WHEN VisitDate LIKE '% March %' THEN 3
            WHEN VisitDate LIKE '% April %' THEN 4
            WHEN VisitDate LIKE '% May %' THEN 5
            WHEN VisitDate LIKE '% June %' THEN 6
            WHEN VisitDate LIKE '% July %' THEN 7
            WHEN VisitDate LIKE '% August %' THEN 8
            WHEN VisitDate LIKE '% September %' THEN 9
            WHEN VisitDate LIKE '% October %' THEN 10
            WHEN VisitDate LIKE '% November %' THEN 11
            WHEN VisitDate LIKE '% December %' THEN 12
            ELSE 0
        END AS MonthNum,

        -- Year
        CASE
            WHEN VisitDate IS NULL THEN 0
            WHEN length(VisitDate) >= 4
                THEN CAST(substr(VisitDate, length(VisitDate) - 3, 4) AS INTEGER)
            ELSE 0
        END AS YearNum
    FROM Cleaned
),

ISO AS (
    SELECT
        Country,
        CASE
            WHEN VisitDate IS NULL THEN '0000-00-00'
            ELSE printf('%04d-%02d-%02d', YearNum, MonthNum, DayNum)
        END AS ISODate
    FROM Parsed
),

FirstVisits AS (
    SELECT
        Country,
        MIN(ISODate) AS FirstVisit
    FROM ISO
    GROUP BY Country
)

SELECT
    ROW_NUMBER() OVER (ORDER BY FirstVisit, Country) AS Seq,
    Country
FROM FirstVisits
ORDER BY FirstVisit, Country;
